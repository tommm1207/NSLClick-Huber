        <svg viewBox="0 0 1000 100" preserveAspectRatio="none" style="width:100%; height:100%;">
            <path d="M0,20 Q500,60 1000,20 L1000,100 L0,100 Z" fill="#000000" />
        </svg>
    </div>
</body>
