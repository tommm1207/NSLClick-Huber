<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NSL Portal – Student Results</title>
    <link rel="icon" type="image/png" href="/logo.png">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --nsl-red: #cc1f1f;
            --nsl-gold: #b8860b; /* Darker Gold as seen in Thai THAN image */
            --nsl-bright-gold: #f2a900;
            --nsl-light-gold: #ffcc22;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Montserrat', sans-serif;
            background: #fff;
            min-height: 100vh;
            color: #1a1a1a;
            /* Subtle diagonal pattern global */
            background: #fff url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="1000" height="1000" viewBox="0 0 1000 1000"><path d="M0 0 L1000 1000 L1000 0 Z" fill="%23f7f7f7"/><path d="M0 1000 L1000 0 L0 0 Z" fill="%23fafafa"/></svg>');
            background-size: cover;
        }

        .container {
            width: 100%;
            margin: 0;
            padding: 0;
        }

        /* Full Page Structure - Replacing Card */
        .result-card {
            background: transparent;
            box-shadow: none;
            border-radius: 0;
            overflow: visible;
            position: relative;
        }

        /* WAVY HEADER */
        .wavy-header {
            position: relative;
            width: 100%;
            height: 140px;
        }
        .wave-svg { width: 100%; height: 100%; display: block; }

        .card-inner {
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px 40px 60px;
            position: relative;
            z-index: 10;
        }

        .card-logo-box { padding-top: 0; margin-top: -15px; margin-bottom: 5px; }
        .card-logo-box img { height: 110px; }

        .profile-flex {
            display: grid;
            grid-template-columns: auto 1fr;
            grid-template-rows: auto 1fr; /* Let bottom row fill space */
            height: 400px;
            column-gap: 40px;
            row-gap: 0;
            align-items: start;
        }

        /* Photo Frame */
        .photo-container {
            grid-row: 1 / span 2;
            width: 280px;
            height: 400px;
            border: 6px solid #fbc02d;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            background: #fff;
        }
        .photo-container img { width: 100%; height: 100%; object-fit: cover; }

        .content-area { 
            grid-column: 2;
            grid-row: 1;
        }

        .student-name {
            font-size: 38px;
            font-weight: 900;
            color: var(--nsl-gold);
            text-transform: capitalize;
            margin-bottom: 5px;
            letter-spacing: -1px;
            line-height: 1.1;
        }

        /* Info Grid - Accurate Spacing */
        .info-grid {
            display: grid;
            grid-template-columns: auto auto 1fr;
            column-gap: 20px;
            row-gap: 6px;
            font-size: 19px;
            margin-bottom: 12px;
        }
        .info-label { font-weight: 800; color: #333; }
        .info-sep { font-weight: 400; color: #555; }
        .info-value { font-weight: 600; color: #444; }

        /* Superpowers Section */
        .sp-section { 
            grid-column: 2;
            grid-row: 2;
            align-self: end; /* Push to bottom of the 400px grid */
            text-align: left; 
        }
        .sp-title {
            font-size: 24px;
            font-weight: 900;
            color: var(--nsl-gold);
            text-transform: uppercase;
            margin-bottom: 8px;
        }
        .sp-yellow-card {
            background: #ffca28;
            border-radius: 12px;
            padding: 12px 20px;
            color: #000;
            font-weight: 700;
            font-size: 16px;
            line-height: 1.4;
            box-shadow: 0 10px 25px rgba(251, 192, 45, 0.12);
            width: 100%;
        }

        .bottom-note {
            font-size: 12px;
            color: #333;
            text-align: center;
            margin-top: 40px;
            line-height: 1.5;
            padding: 0 40px;
            font-weight: 600;
        }

        /* Action Button */
        .action-box { text-align: center; margin-top: 30px; }
        .video-btn {
            display: inline-block;
            background: var(--nsl-red);
            color: white;
            text-decoration: none;
            padding: 18px 80px;
            border-radius: 50px;
            font-size: 20px;
            font-weight: 900;
            box-shadow: 0 8px 25px rgba(204, 31, 31, 0.35);
            transition: 0.3s;
        }
        .video-btn:hover { background: #b01a1a; transform: translateY(-3px); }

        /* WAVY FOOTER - Complete the Flag */
        .wavy-footer { height: 70px; background: transparent; }

        /* Logout Button */
        .logout-link {
            position: absolute;
            top: 20px;
            right: 40px;
            z-index: 100;
            color: #fff;
            text-decoration: none;
            font-size: 14px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 8px 16px;
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 8px;
            transition: 0.3s;
        }
        .logout-link:hover {
            background: rgba(255,255,255,0.1);
            border-color: #fff;
        }

        @media (max-width: 900px) {
            .container { padding: 0 10px; }
            .card-inner { padding: 0 15px 30px; }
            .profile-flex { 
                grid-template-columns: auto 1fr;
                column-gap: 15px;
                height: auto;
            }
            .photo-container { 
                grid-row: 1;
                width: 120px; 
                height: 180px; 
                border-width: 3px; 
            }
            .content-area {
                grid-column: 2;
                grid-row: 1;
                height: 180px;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
            }
            .sp-section {
                grid-column: 1 / span 2;
                grid-row: 2;
                margin-top: 15px;
            }
            .student-name { font-size: 24px; margin-bottom: 15px; }
            .info-grid { font-size: 13px; row-gap: 8px; column-gap: 10px; margin-bottom: 0; }
            .sp-title { font-size: 16px; margin-bottom: 5px; }
            .sp-yellow-card { padding: 8px 12px; border-radius: 8px; font-size: 12px; }
            .video-btn { padding: 12px 30px; font-size: 14px; }
            .bottom-note { font-size: 10px; padding: 0 10px; margin-top: 20px; }
            .wavy-footer { height: 40px; }
            .wavy-header { height: 100px; }
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- Exact Waves from Image 2 -->
        <div class="wavy-header">
            <a href="/logout" class="logout-link">Abmelden</a>
            <svg viewBox="0 0 1000 200" preserveAspectRatio="none" style="width:100%; height:100%;">
                <path d="M0,0 L1000,0 L1000,140 Q500,180 0,140 Z" fill="#f2a900" />
                <path d="M0,0 L1000,0 L1000,100 Q500,140 0,100 Z" fill="#cc1f1f" />
            </svg>
        </div>

            <div class="card-inner">
                <div class="card-logo-box">
                    <img src="/logo.png" alt="NSL">
                </div>

                <div class="profile-flex">
                    <div class="photo-container">
                        <img src="<%= student.LinkAnh || 'https://placehold.co/250x320?text=Photo' %>" alt="<%= student.HoTen %>">
                    </div>

                    <div class="content-area">
                        <h2 class="student-name"><%= student.HoTen %></h2>
                        <div class="info-grid">
                            <div class="info-label">Geburtsjahr</div>
                            <div class="info-sep">:</div>
                            <div class="info-value"><%= student.NgaySinh ? student.NgaySinh.split('/').pop() : '2002' %></div>

                            <div class="info-label">Deutsch B1</div>
                            <div class="info-sep">:</div>
                            <div class="info-value">B1</div>

                            <div class="info-label">1/2 (Test)</div>
                            <div class="info-sep">:</div>
                            <div class="info-value"><%= student.Diem1 || '—' %></div>

                            <div class="info-label">2/2 (Interview)</div>
                            <div class="info-sep">:</div>
                            <div class="info-value"><%= student.Diem2 || '—' %></div>

                            <div class="info-label">Total</div>
                            <div class="info-sep">:</div>
                            <div class="info-value"><%= student.Total || '69' %></div>

                            <div class="info-label">Verfügbarkeit</div>
                            <div class="info-sep">:</div>
                            <div class="info-value">september 2026</div>
                        </div>
                    </div>

                    <div class="sp-section">
                        <h3 class="sp-title">SUPERPOWERS</h3>
                        <div class="sp-yellow-card">
                            <p>1. Veranwortungsbewusster Arbeiter</p>
                            <p>2. Freundlicher Kundenberater</p>
                            <p>3. Flexibler Unterstützer</p>
                        </div>
                    </div>
                </div>

                <p class="bottom-note">
                    Der NSL-Score basiert auf einer Reihe umfassender Beurteilungen zur Bewertung des IQ, der Entscheidungsfindung und verschiedener anderer Fähigkeiten und erreicht einen durchschnittlichen Benchmark von 48.
                </p>

                <% if (student.LinkVideo) { %>
                <div class="action-box">
                    <a href="<%= student.LinkVideo %>" target="_blank" class="video-btn">Klicken, um das Video anzusehen</a>
                </div>
                <% } %>
            </div>


        <% if (student.LinkCV) { %>
        <%
            let cvUrl = student.LinkCV;
            const m = cvUrl.match(/\/d\/([a-zA-Z0-9_-]+)/);
            if (m) cvUrl = 'https://drive.google.com/file/d/' + m[1] + '/preview';
        %>
        <div style="margin: 0 auto 60px; max-width: 1000px; padding: 0 40px;">
            <iframe style="width: 100%; height: 950px; border: none; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);" src="<%= cvUrl %>"></iframe>
        </div>
        <% } %>

        <!-- Black Wave Footer (Bottom of Page) -->
        <div class="wavy-footer" style="margin-top: auto;">
            <svg viewBox="0 0 1000 100" preserveAspectRatio="none" style="width:100%; height:100%;">
                <path d="M0,20 Q500,60 1000,20 L1000,100 L0,100 Z" fill="#000000" />
            </svg>
        </div>
    </div>

</body>
</html>
