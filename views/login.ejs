<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NSL Portal – Sign In</title>
    <link rel="icon" type="image/png" href="/logo.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --nsl-red: #cc1f1f;
            --nsl-gold: #f2a900;
            --nsl-light-gold: #ffcc22;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            background: #fff;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden; /* No scroll */
            /* Subtle diagonal pattern */
            background-image: repeating-linear-gradient(45deg, #f9f9f9 0, #f9f9f9 1px, transparent 0, transparent 50%);
            background-size: 30px 30px;
        }

        .login-page-container {
            width: 100%;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .wavy-header {
            width: 100vw;
            height: 120px; /* Shallower */
            position: relative;
        }

        .login-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
            position: relative;
        }

        .login-form-box {
            background: transparent;
            width: 100%;
            max-width: 500px;
            text-align: center;
        }

        .logo-box {
            margin-bottom: 20px; /* Reduced */
        }
        .logo-box img { height: 180px; }

        h1 {
            font-size: 42px;
            font-weight: 900;
            color: var(--nsl-gold);
            margin-bottom: 10px; /* Reduced */
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .subtitle {
            font-size: 18px;
            color: #666;
            margin-bottom: 30px; /* Reduced */
            font-weight: 500;
        }

        /* FORM */
        .form-group {
            text-align: left;
            margin-bottom: 24px;
        }
        .form-group label {
            display: block;
            text-align: left;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 10px;
            color: #999; /* Dimm label */
            letter-spacing: 0.5px;
        }
        .input-control {
            width: 100%;
            padding: 16px 20px;
            border: 2px solid #eee;
            border-radius: 12px;
            font-size: 16px;
            font-family: inherit;
            outline: none;
            transition: border-color 0.2s;
        }
        .input-control:focus { border-color: var(--nsl-gold); }

        .btn-submit {
            width: 100%;
            background: var(--nsl-red);
            color: white;
            border: none;
            padding: 16px;
            border-radius: 50px;
            font-size: 18px;
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 6px 20px rgba(204, 31, 31, 0.3);
            transition: all 0.25s;
            margin-top: 10px;
        }
        .btn-submit:hover { background: #b01a1a; transform: translateY(-2px); }

        .error-msg {
            background: #fff5f5;
            color: var(--nsl-red);
            padding: 12px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 24px;
            border: 1px solid #fed7d7;
        }

        .footer-text-bottom {
            margin-top: 30px; /* Reduced from 50px */
            font-size: 12px;
            color: #bbb;
            font-weight: 600;
        }

        @media (max-width: 600px) {
            .login-content { padding: 20px 30px; }
            .logo-box { margin-bottom: 25px; }
            .logo-box img { height: 140px; }
            h1 { font-size: 32px; }
            .subtitle { font-size: 15px; margin-bottom: 30px; }
            .wavy-header { height: 75px; }
            .footer-text-bottom { margin-top: 20px; }
        }
    </style>
</head>
<body>

    <div class="login-page-container">
        <!-- Wavy Header Full Width -->
        <div class="wavy-header">
            <svg viewBox="0 0 1000 150" preserveAspectRatio="none" style="width: 100%; height: 100%;">
                <path d="M0,0 L1000,0 L1000,100 Q500,130 0,100 Z" fill="#f2a900" />
                <path d="M0,0 L1000,0 L1000,70 Q500,100 0,70 Z" fill="#cc1f1f" />
            </svg>
        </div>

        <div class="login-content">
            <div class="login-form-box">
                <div class="logo-box">
                    <img src="/logo.png" alt="NSL">
                </div>

                <h1>NSL Portal</h1>
                <p class="subtitle">Access your test and interview results</p>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="error-msg"><%= error %></div>
                <% } %>

                <form action="/login" method="POST">
                    <div class="form-group">
                        <label>Login Credentials</label>
                        <input type="text" name="input" class="input-control" placeholder="Phone Number or Password" required>
                    </div>

                    <button type="submit" class="btn-submit">Sign In</button>
                </form>

                <p class="footer-text-bottom">
                    NSL – Study & Work in Germany
                </p>
            </div>
        </div>

        <!-- Black Wave Footer (Bottom) - Increased Height -->
        <div style="height: 100px; margin-top: auto;">
            <svg viewBox="0 0 1000 100" preserveAspectRatio="none" style="width: 100%; height: 100%;">
                <path d="M0,20 Q500,60 1000,20 L1000,100 L0,100 Z" fill="#000000" />
            </svg>
        </div>
    </div>

</body>
</html>
